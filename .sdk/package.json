{
  "name": "build-shodan-entitydb-sdk",
  "version": "0.0.1",
  "description": "ShodanEntitydb SDK Project",
  "scripts": {
    "generate": "voxgig-model model/sdk.jsonic",
    "watch-generate": "voxgig-model -w model/sdk.jsonic",
    "dry-generate": "voxgig-model -y model/sdk.jsonic",
    "watch-dry-generate": "voxgig-model -w -y model/sdk.jsonic",
    "test-model": "voxgig-model test/test.jsonic",
    "watch-test-model": "voxgig-model -w test/test.jsonic",
    "watch": "tsc --build src -w",
    "build": "tsc --build src",
    "test": "echo no-test",
    "clean": "rm -rf dist dist-test node_modules yarn.lock package-lock.json",
    "reset": "npm run clean && npm i && npm run build && npm test",
    "add-target": "voxgig-sdkgen target add",
    "dry-add-target": "voxgig-sdkgen -y target add",
    "add-feature": "voxgig-sdkgen feature add",
    "dry-add-feature": "voxgig-sdkgen -y feature add"
  },
  "author": "ShodanEntitydb",
  "license": "$$const.License$$",
  "devDependencies": {
    "@types/node": ">=25.6",
    "@voxgig/apidef": "^5.11.0",
    "@voxgig/model": ">=8.1",
    "@voxgig/sdkgen": "^0.45.0",
    "@voxgig/struct": ">=0.1.0",
    "@voxgig/util": ">=0.4",
    "aontu": ">=0.44",
    "jostraca": ">=0.29",
    "typescript": ">=6.0"
  }
}
